# ============================================================
# Fiscalo — configuración de la API e-CF
# Copia este archivo a .env.local y rellena los valores.
# ============================================================

# --- Desarrollo: dev-proxy de Vite -------------------------------
# La clave NUNCA se envía al navegador: el proxy de Vite reescribe
# /api -> API_PROXY_TARGET e inyecta el header X-API-KEY.
API_PROXY_TARGET=https://tu-backend-ecf.example.com
API_KEY=tu-api-key-secreta

# Usuario emisor por defecto (campo user_id en POST /api/facturas)
VITE_DEFAULT_USER_ID=1

# tenant_id (código de empresa) enviado en POST /api/auth/login (multi-tenant).
# Vacío => el backend resuelve por email (único global). 1 = Gratex EIRL.
VITE_TENANT_ID=1

# --- Producción (build estático, sin dev-proxy) ------------------
# Solo si despliegas el front sin un proxy delante. Si defines
# VITE_API_KEY, la clave QUEDA EMBEBIDA en el bundle del navegador
# (úsalo solo con claves internas / de prueba).
# VITE_API_BASE_URL=https://tu-backend-ecf.example.com
# VITE_API_KEY=
